# Настройка полноэкранного NVL-режима 
init -1:
    style nvl_window:
        background None                  # Без фона — текст прямо на сцене
        xalign 0.5                       # Центрирование по горизонтали
        yalign 0.75                       # Центрирование по вертикали
        xpos 0.0
        ypos 0.0
        xsize 1.0                        # Ширина — 100% экрана
        ysize 1.0                        # Высота — 100% экрана
        xfill True
        yfill True
        padding (50, 80)                 # Отступы от краёв: слева/справа 50px, сверху/снизу 80px (можно менять)

    style nvl_vbox:
        spacing 30                       # Расстояние между абзацами

    style nvl_dialogue:
        size 32                          # Размер шрифта основного текста
        color "#ffffff"
        outlines [(4, "#000000aa", 0, 0)] # Чёрная обводка для читаемости на любом фоне
        line_spacing 10
        slow_cps 30                      # Скорость появления текста (символов в секунду)

    style nvl_label:
        bold True
        size 40
        color "#ffffff"
        outlines [(5, "#000000aa", 0, 0)]
        text_align 0.5                   # Центрирование заголовков (если будут)

# ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ И ИИ
init python:
    import requests
    import json

    def generate_ending_with_ollama():
        # Собираем summary выбора игрока
        summary = "Краткий отчёт о выборе игрока:\n"
        summary += "\n".join(morality_history[-10:])  # Последние 10 действий
        summary += f"\n\nФлаги: Милосердие={mercy}, Жестокость={cruelty}, Прагматизм={pragmatism}, "
        summary += f"Смелость={bravery}, Осторожность={caution}, Обман={deception}, Эмпатия={empathy}\n"
        summary += f"Спас мальчика: {saved_boy}, Спас лучника: {saved_archer}, Убил жрицу: {killed_priestess}, "
        summary += f"Разрушил алтарь: {destroyed_altar}, Без убийств: {no_kills}"

        prompt = f"""
        Ты — мастер визуальных новелл в стиле тёмного фэнтези.
        Напиши эмоциональную концовку (300-500 слов) на русском языке для игры "Тень над Восточным Трактом".
        Главный герой — рыцарь Альдрин.
        Жрица Тумана побеждена или сдалась.
        Учитывай выборы игрока:
        {summary}

        Сделай концовку coherent, с описанием чувств, последствий и финальным посылом.
        Если много милосердия — хэппи-энд.
        Если много жестокости — трагичный или тёмный.
        Если прагматизм доминирует — нейтральный, эффективный.
        Всегда заканчивай фразой вроде "Конец пути рыцаря Альдрина."
        """

        url = "http://localhost:11434/api/generate"
        data = {
            "model": "qwen3:8b",  # Твоя модель
            "prompt": prompt,
            "stream": False,
            "options": {"temperature": 0.8, "num_ctx": 8192}
        }

        try:
            response = requests.post(url, json=data, timeout=120)
            if response.status_code == 200:
                result = response.json()
                return result.get("response", "Ошибка генерации.").strip()
            else:
                return f"Ошибка Ollama: {response.status_code}\nЗапусти ollama serve и попробуй снова."
        except Exception as e:
            return f"Не удалось подключиться к Ollama: {str(e)}\nУбедись, что Ollama запущена."


