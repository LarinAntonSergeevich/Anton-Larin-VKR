# Функция генерации концовки и анализ игрока через Ollama
init python:
    import requests
    import json

    def split_text(text, max_len=340):
        words = text.split()
        chunks = []
        current = ""

        for word in words:
            if len(current) + len(word) + 1 <= max_len:
                current += word + " "
            else:
                chunks.append(current.strip())
                current = word + " "

        if current:
            chunks.append(current.strip())

        return chunks

    def clamp_score(value):
        return max(0, min(100, int(value)))

    def calculate_goleman_scores():
        # 1. Самосознание
        self_awareness = 50
        self_awareness += pragmatism * 8
        self_awareness += caution * 5
        self_awareness += bravery * 3
        self_awareness -= cruelty * 4
        self_awareness -= deception * 3

        # 2. Самоконтроль
        self_regulation = 50
        self_regulation += caution * 7
        self_regulation += mercy * 4
        self_regulation -= cruelty * 9
        self_regulation -= deception * 4
        self_regulation -= bravery * 2

        # 3. Мотивация
        motivation = 45
        motivation += bravery * 8
        motivation += pragmatism * 5
        motivation += sacrifice * 6
        motivation += 8 if save_g else 0
        motivation += 5 if destroyed_altar else 0

        # 4. Эмпатия
        empathy_score = 40
        empathy_score += empathy * 10
        empathy_score += mercy * 8
        empathy_score += 8 if saved_boy else 0
        empathy_score += 8 if saved_archer else 0
        empathy_score += 6 if saved_man else 0
        empathy_score += 10 if save_g else 0
        empathy_score -= cruelty * 10
        empathy_score -= deception * 3

        # 5. Социальные навыки
        social_skills = 40
        social_skills += empathy * 6
        social_skills += mercy * 5
        social_skills += pragmatism * 4
        social_skills += 8 if boy_guides else 0
        social_skills += 8 if man_follows else 0
        social_skills += 8 if saved_archer else 0
        social_skills -= cruelty * 7
        social_skills -= deception * 4

        # Общий EI по Гоулману
        total_ei = int((
            self_awareness +
            self_regulation +
            motivation +
            empathy_score +
            social_skills
        ) / 5)

        return {
            "self_awareness": clamp_score(self_awareness),
            "self_regulation": clamp_score(self_regulation),
            "motivation": clamp_score(motivation),
            "empathy_score": clamp_score(empathy_score),
            "social_skills": clamp_score(social_skills),
            "total_ei": clamp_score(total_ei),
        }

    def generate_ending_with_ollama():
        summary = "Ключевые события и выборы игрока:\n"
        for event in morality_history:
            summary += "- " + event + "\n"

        summary += f"\nФлаги персонажа:\n"
        summary += f"• Милосердие: {mercy}\n"
        summary += f"• Жестокость: {cruelty}\n"
        summary += f"• Прагматизм: {pragmatism}\n"
        summary += f"• Смелость: {bravery}\n"
        summary += f"• Осторожность: {caution}\n"
        summary += f"• Обман: {deception}\n"
        summary += f"• Эмпатия: {empathy}\n"
        summary += f"• Жертвенность: {sacrifice}\n\n"

        summary += f"• Спас всех ключевых персонажей: {'Да' if saved_everyone else 'Нет'}\n"

        summary += f"\nФакты:\n"
        summary += f"• Спас мальчика: {'Да' if saved_boy else 'Нет'}\n"
        summary += f"• Мальчик сопровождал героя: {'Да' if boy_guides else 'Нет'}\n"
        summary += f"• Спас лучника Лиора: {'Да' if saved_archer else 'Нет'}\n"
        summary += f"• Спас измождённого мужчину: {'Да' if saved_man else 'Нет'}\n"
        summary += f"• Измождённый мужчина следовал за героем: {'Да' if man_follows else 'Нет'}\n"
        summary += f"• Спас девушку: {'Да' if save_g else 'Нет'}\n"
        summary += f"• Убил жрицу: {'Да' if killed_priestess else 'Нет'}\n"
        summary += f"• Разрушил алтарь: {'Да' if destroyed_altar else 'Нет'}\n"
        summary += f"• Прошёл без убийств: {'Да' if no_kills else 'Нет'}\n"

        prompt = f"""
Ты — талантливый писатель тёмного фэнтези, мастер эмоциональных и глубоких финалов.
Напиши финальную концовку визуальной новеллы "Тень над Восточным Трактом" на русском языке.
Главный герой — рыцарь Альдрин.

Обязательно учти ВСЁ ниже:

{summary}

Правила:
- Длина: 300–500 слов.
- Стиль: литературный, атмосферный, с описанием чувств, природы, последствий.
- Обязательно учитывай судьбу спутников: мальчика, лучника Лиора и измождённого мужчины.
- Если мальчик сопровождал героя, упомяни, как это повлияло на путь.
- Если мужчина был спасён или шёл вместе с героем, отрази это в финале.
- Если милосердие и эмпатия высокие — сделай светлый, вдохновляющий финал.
- Если жестокость и обман доминируют — мрачный, трагичный или циничный.
- Если прагматизм и смелость — нейтральный, но эффективный.
- Если игрок прошёл без убийств — подчеркни чистоту пути.
- Заверши мощной финальной фразой о судьбе Альдрина.
- Не повторяй события игры дословно — создай новый нарратив на основе выборов.
- Пиши только текст концовки, без заголовков и комментариев.
"""

        url = "http://localhost:11434/api/generate"
        payload = {
            "model": "qwen3:8b",
            "prompt": prompt,
            "stream": False,
            "options": {
                "temperature": 0.85,
                "num_ctx": 8192,
                "top_p": 0.9
            }
        }

        try:
            response = requests.post(url, json=payload, timeout=180)
            if response.status_code == 200:
                result = response.json()
                text = result.get("response", "").strip()
                if text:
                    return text
                else:
                    return "Туман поглотил слова... Но ты победил. Конец."
            else:
                return f"Туман слишком густ... (Ошибка Ollama: {response.status_code})\nЗапусти ollama serve и перезапусти игру."
        except Exception as e:
            return f"Рыцарь потерялся в тумане генерации...\nОшибка: {str(e)}\n\nЗапусти Ollama и попробуй снова.\n\nFallback: Ты победил жрицу и рассеял туман. Фессалия спасена."

    def analyze_player_profile():
        scores = calculate_goleman_scores()

        summary = f"""
